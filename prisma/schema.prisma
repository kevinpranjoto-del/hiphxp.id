generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  EDITOR
  WRITER
  MUSICIAN
}

enum UserAccountType {
  SUPER_ADMIN
  ADMIN
  EDITOR
  WRITER
  MUSICIAN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum MediaPlatform {
  SPOTIFY
  APPLE_MUSIC
  YOUTUBE
  TIKTOK
  INSTAGRAM
}

enum EventCategory {
  FESTIVAL
  GIG
  RAP_BATTLE
  STREET_EVENT
  WORKSHOP
  COMPETITION
}

enum DirectoryStatus {
  DRAFT
  ACTIVE
  REVIEW
  REJECTED
}

enum PartnershipStatus {
  NEW
  REVIEW
  APPROVED
  REJECTED
  CLOSED
}

enum NotificationChannel {
  EMAIL
  PUSH
  SYSTEM
}

enum ActivityType {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  VERIFY
  APPROVE
  REJECT
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        RoleName @unique
  description String?
  users       User[]
  permissions Permission[]
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  deleted_at  DateTime?

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  roles       Role[]
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  deleted_at  DateTime?

  @@map("permissions")
}

model User {
  id               String           @id @default(uuid()) @db.Uuid
  email            String           @unique
  password_hash    String
  account_type     UserAccountType  @default(MUSICIAN)
  role_id          String?          @db.Uuid
  role             Role?            @relation(fields: [role_id], references: [id])
  is_active        Boolean          @default(true)
  email_verified   Boolean          @default(false)
  last_login_at    DateTime?
  musician_profile MusicianProfile?
  author           Author?
  refresh_tokens   RefreshToken[]
  password_resets  PasswordResetToken[]
  email_verifications EmailVerificationToken[]
  login_history    LoginHistory[]
  activity_logs    ActivityLog[]
  notifications    Notification[]
  articles         Article[]
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  deleted_at       DateTime?

  @@map("users")
}

model MusicianProfile {
  id                   String             @id @default(uuid()) @db.Uuid
  user_id              String             @unique @db.Uuid
  user                 User               @relation(fields: [user_id], references: [id])
  artist_name          String
  real_name            String
  whatsapp             String?
  city                 String?
  label                String?
  instagram            String?
  tiktok               String?
  spotify_artist_url   String?
  apple_music_url     String?
  youtube_channel      String?
  profile_photo        String?
  bio                  String?
  verification_status  VerificationStatus @default(PENDING)
  is_verified          Boolean            @default(false)
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  deleted_at           DateTime?

  @@map("musician_profiles")
}

model Author {
  id           String    @id @default(uuid()) @db.Uuid
  user_id      String?   @unique @db.Uuid
  user         User?     @relation(fields: [user_id], references: [id])
  display_name String
  slug         String    @unique
  bio          String?
  photo        String?
  articles     Article[]
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  @@map("authors")
}

model Category {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @unique
  slug         String    @unique
  description  String?
  articles     Article[]
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  @@map("categories")
}

model Tag {
  id           String        @id @default(uuid()) @db.Uuid
  name         String        @unique
  slug         String        @unique
  articles     ArticleTag[]
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  deleted_at   DateTime?

  @@map("tags")
}

model Article {
  id                String              @id @default(uuid()) @db.Uuid
  title             String
  excerpt           String?
  content           String
  slug              String              @unique
  featured_image    String?
  thumbnail         String?
  status            ArticleStatus       @default(DRAFT)
  featured          Boolean             @default(false)
  seo_title         String?
  meta_description  String?
  canonical_url     String?
  og_image          String?
  keywords          String?
  schema_org        String?
  view_count        Int                 @default(0)
  published_at      DateTime?
  author_id         String?             @db.Uuid
  author            Author?             @relation(fields: [author_id], references: [id])
  category_id       String?             @db.Uuid
  category          Category?           @relation(fields: [category_id], references: [id])
  user_id           String?             @db.Uuid
  user              User?               @relation(fields: [user_id], references: [id])
  tags              ArticleTag[]
  media_embeds      ArticleMediaEmbed[]
  analytics         AnalyticsEvent[]
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt
  deleted_at        DateTime?

  @@map("articles")
}

model ArticleTag {
  id         String   @id @default(uuid()) @db.Uuid
  article_id String   @db.Uuid
  article    Article  @relation(fields: [article_id], references: [id])
  tag_id     String   @db.Uuid
  tag        Tag      @relation(fields: [tag_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?

  @@unique([article_id, tag_id])
  @@map("article_tags")
}

model ArticleMediaEmbed {
  id          String        @id @default(uuid()) @db.Uuid
  article_id  String        @db.Uuid
  article     Article       @relation(fields: [article_id], references: [id])
  platform    MediaPlatform
  embed_url   String
  embed_code  String?
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  deleted_at  DateTime?

  @@map("article_media_embeds")
}

model Genre {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @unique
  slug         String    @unique
  artists      Artist[]
  songs        Song[]
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  @@map("genres")
}

