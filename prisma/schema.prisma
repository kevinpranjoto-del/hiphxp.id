  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  @@map("labels")
}

model Producer {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @unique
  slug         String    @unique
  bio          String?
  website      String?
  instagram    String?
  songs        Song[]
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  @@map("producers")
}

model Artist {
  id                 String    @id @default(uuid()) @db.Uuid
  name               String
  slug               String    @unique
  real_name          String?
  bio                String?
  city               String?
  province           String?
  genre_id           String?   @db.Uuid
  genre              Genre?    @relation(fields: [genre_id], references: [id])
  label_id           String?   @db.Uuid
  label              Label?    @relation(fields: [label_id], references: [id])
  instagram          String?
  tiktok             String?
  youtube            String?
  spotify            String?
  website            String?
  whatsapp           String?
  email              String?
  is_verified        Boolean   @default(false)
  albums             Album[]
  singles            Single[]
  songs              Song[]
  music_reviews      MusicReview[]
  release_radar      ReleaseRadar[]
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  deleted_at         DateTime?

  @@map("artists")
}

model Album {
  id           String    @id @default(uuid()) @db.Uuid
  title        String
  slug         String    @unique
  artist_id    String    @db.Uuid
  artist       Artist    @relation(fields: [artist_id], references: [id])
  label_id     String?   @db.Uuid
  label        Label?    @relation(fields: [label_id], references: [id])
  cover_image  String?
  release_date DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  @@map("albums")
}

model Single {
